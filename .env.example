# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# 1. Sign up at https://neon.tech (free tier works)
# 2. Create a new project — copy the "Pooled connection" string
# 3. Paste it below (looks like: postgresql://user:pass@host.neon.tech/dbname?sslmode=require)
DATABASE_URL=""

# ─── Auth.js v5 ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Or visit: https://generate-secret.vercel.app/32
AUTH_SECRET=""

# In production set this to your real domain (https://yourdomain.com)
# In dev, leave blank — Auth.js auto-detects http://localhost:3000
AUTH_URL=""

# ─── Google OAuth (optional but recommended) ────────────────────────────────
# 1. Visit https://console.cloud.google.com/apis/credentials
# 2. Create OAuth client ID → Web application
# 3. Authorized redirect URIs:
#      http://localhost:3000/api/auth/callback/google   (dev)
#      https://yourdomain.com/api/auth/callback/google  (prod)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OpenAI (already required for AI rewrites) ──────────────────────────────
OPENAI_API_KEY=""
